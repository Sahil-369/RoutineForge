<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@color/bg_dark" android:fillViewport="true">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="16dp">

        <!-- Header -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Profile" android:textSize="22sp" android:textColor="@color/text_primary"
            android:textStyle="bold" android:layout_marginBottom="20dp"/>

        <!-- Why Started Card -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:background="@drawable/bg_card"
            android:padding="20dp" android:layout_marginBottom="16dp">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="My Intention" android:textSize="13sp"
                android:textColor="@color/text_secondary" android:layout_marginBottom="10dp"/>

            <TextView android:id="@+id/tv_why_started"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="&quot;Set your intention&quot;" android:textSize="17sp"
                android:textColor="@color/text_primary" android:textStyle="italic"
                android:lineSpacingMultiplier="1.4"/>
        </LinearLayout>

        <!-- Stats Title -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Your Stats" android:textSize="17sp" android:textColor="@color/text_primary"
            android:textStyle="bold" android:layout_marginBottom="12dp"/>

        <!-- Streak row -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="10dp">

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical"
                android:background="@drawable/bg_stat_card" android:padding="16dp"
                android:layout_marginEnd="6dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Current Streak" android:textSize="12sp"
                    android:textColor="@color/text_secondary" android:layout_marginBottom="8dp"/>
                <TextView android:id="@+id/tv_stat_streak"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="0 days" android:textSize="22sp" android:textColor="@color/accent_orange"
                    android:textStyle="bold"/>
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical"
                android:background="@drawable/bg_stat_card" android:padding="16dp"
                android:layout_marginStart="6dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Best Streak" android:textSize="12sp"
                    android:textColor="@color/text_secondary" android:layout_marginBottom="8dp"/>
                <TextView android:id="@+id/tv_stat_best_streak"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="0 days" android:textSize="22sp" android:textColor="@color/accent_amber"
                    android:textStyle="bold"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Total days & tasks row -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="10dp">

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical"
                android:background="@drawable/bg_stat_card" android:padding="16dp"
                android:layout_marginEnd="6dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Perfect Days" android:textSize="12sp"
                    android:textColor="@color/text_secondary" android:layout_marginBottom="8dp"/>
                <TextView android:id="@+id/tv_stat_total_days"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="0" android:textSize="22sp" android:textColor="@color/accent_green"
                    android:textStyle="bold"/>
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical"
                android:background="@drawable/bg_stat_card" android:padding="16dp"
                android:layout_marginStart="6dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="✅  Tasks Completed" android:textSize="12sp"
                    android:textColor="@color/text_secondary" android:layout_marginBottom="8dp"/>
                <TextView android:id="@+id/tv_stat_tasks_done"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="0" android:textSize="22sp" android:textColor="@color/text_primary"
                    android:textStyle="bold"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Tasks created -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:background="@drawable/bg_stat_card"
            android:padding="16dp" android:layout_marginBottom="32dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Tasks in Routine" android:textSize="12sp"
                android:textColor="@color/text_secondary" android:layout_marginBottom="8dp"/>
            <TextView android:id="@+id/tv_stat_tasks_created"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="0 tasks" android:textSize="22sp" android:textColor="@color/text_primary"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- App info -->
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="RoutineForge v1.0\nAll data stored locally on your device"
            android:textSize="12sp" android:textColor="@color/text_hint"
            android:gravity="center" android:layout_marginBottom="16dp"/>

    </LinearLayout>
</ScrollView>
